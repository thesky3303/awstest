{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ticketing"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Seoul",
  "title": "Ticketing Service Overview",
  "uid": "ticketing-overview",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "RDS Writer CPU",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "aws_rds_cpuutilization_average{dimension_DBInstanceIdentifier=~\".*writer.*\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":50},{"color":"red","value":80}] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Redis Memory %",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "aws_elasticache_database_memory_usage_percentage_average", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":50},{"color":"red","value":75}] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Redis Cache Hit Rate",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m])) * 100", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{"color":"red","value":null},{"color":"yellow","value":50},{"color":"green","value":80}] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "SQS Queue Depth",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "aws_sqs_approximate_number_of_messages_visible_maximum", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":100},{"color":"red","value":500}] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 10,
      "type": "row",
      "title": "RDS MySQL",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "RDS CPU Utilization",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "aws_rds_cpuutilization_average", "legendFormat": "{{dimension_DBInstanceIdentifier}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":50},{"color":"red","value":80}] } }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "RDS Database Connections",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "aws_rds_database_connections_average", "legendFormat": "{{dimension_DBInstanceIdentifier}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":50},{"color":"red","value":100}] } }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "RDS Replica Lag",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "aws_rds_replica_lag_average", "legendFormat": "{{dimension_DBInstanceIdentifier}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "min": 0, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":3},{"color":"red","value":10}] } }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] } }
    },
    {
      "id": 20,
      "type": "row",
      "title": "ElastiCache Redis",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Redis Cache Hit Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m])) * 100", "legendFormat": "Hit Rate", "refId": "A" },
        { "expr": "rate(redis_keyspace_hits_total[5m])", "legendFormat": "Hits/s", "refId": "B" },
        { "expr": "rate(redis_keyspace_misses_total[5m])", "legendFormat": "Misses/s", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "custom": { "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [{"matcher":{"id":"byName","options":"Hits/s"},"properties":[{"id":"unit","value":"ops"}]},{"matcher":{"id":"byName","options":"Misses/s"},"properties":[{"id":"unit","value":"ops"}]}] },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Redis Memory Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "aws_elasticache_database_memory_usage_percentage_average", "legendFormat": "Memory % (CloudWatch)", "refId": "A" },
        { "expr": "redis_used_memory_bytes / 1024 / 1024", "legendFormat": "Used Memory (MB)", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "custom": { "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [{"matcher":{"id":"byName","options":"Used Memory (MB)"},"properties":[{"id":"unit","value":"decmbytes"}]}] },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Redis Connected Clients",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "redis_connected_clients", "legendFormat": "Connected Clients", "refId": "A" },
        { "expr": "aws_elasticache_curr_connections_average", "legendFormat": "Connections (CloudWatch)", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Redis Commands/sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(redis_commands_processed_total[5m])", "legendFormat": "Commands/s", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops", "min": 0, "custom": { "fillOpacity": 10, "lineWidth": 2, "gradientMode": "scheme" } }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] } }
    },
    {
      "id": 30,
      "type": "row",
      "title": "SQS Queue",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "SQS Messages Visible (Queue Depth)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "aws_sqs_approximate_number_of_messages_visible_maximum", "legendFormat": "{{dimension_QueueName}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "fillOpacity": 20, "lineWidth": 2, "gradientMode": "scheme" }, "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":100},{"color":"red","value":500}] } }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] } }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "SQS Messages Sent",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "aws_sqs_number_of_messages_sent_sum", "legendFormat": "{{dimension_QueueName}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] } }
    },
    {
      "id": 40,
      "type": "row",
      "title": "EKS Application Services",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 47 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 15,
      "type": "stat",
      "title": "event-svc",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"event-svc\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "mappings": [{"type":"value","options":{"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}}}], "thresholds": { "mode": "absolute", "steps": [{"color":"red","value":null},{"color":"green","value":1}] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 16,
      "type": "stat",
      "title": "reserv-svc",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"reserv-svc\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "mappings": [{"type":"value","options":{"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}}}], "thresholds": { "mode": "absolute", "steps": [{"color":"red","value":null},{"color":"green","value":1}] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 17,
      "type": "stat",
      "title": "worker-svc",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"worker-svc\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "mappings": [{"type":"value","options":{"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}}}], "thresholds": { "mode": "absolute", "steps": [{"color":"red","value":null},{"color":"green","value":1}] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 50,
      "type": "row",
      "title": "Monitoring EC2",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 52 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "EC2 CPU Usage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 53 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU Usage %", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "fillOpacity": 20, "lineWidth": 2, "gradientMode": "scheme" }, "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":50},{"color":"red","value":80}] } }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] } }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "EC2 Memory Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 53 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "Memory Usage %", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "fillOpacity": 20, "lineWidth": 2, "gradientMode": "scheme" }, "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":60},{"color":"red","value":85}] } }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] } }
    }
  ]
}
